# ============================================
# Student Management System - Environment Config
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Google Apps Script deployed web app URL
VITE_API_URL=https://script.google.com/macros/s/YOUR_DEPLOYED_URL/exec

# Institute geolocation for attendance radius check
VITE_INSTITUTE_LAT=19.07157800
VITE_INSTITUTE_LNG=73.14348780
VITE_ALLOWED_RADIUS=100

# Face recognition match threshold (lower = stricter)
VITE_FACE_MATCH_THRESHOLD=0.6
